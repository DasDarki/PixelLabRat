# Copy to .env and fill in. .env is gitignored.
# Your PixelLab API token from https://pixellab.ai/account
API_KEY=your-pixellab-token-here

# Embedded Claude agent ("Art-Director") — usually NOT needed here: if you're logged
# into Claude Code, the app auto-detects it; otherwise use the in-app "Mit Claude
# verbinden" button (token is stored encrypted in the OS keychain, not in this file).
# These manual options also work (API key wins if both are set):
#   ANTHROPIC_API_KEY        pay-per-token, direct SDK
#   CLAUDE_CODE_OAUTH_TOKEN  Claude subscription token (`claude setup-token`)
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_CODE_OAUTH_TOKEN=

# Optional overrides
# PIXELLAB_API_KEY=        # takes precedence over API_KEY
# PIXELLAB_BASE_URL=https://api.pixellab.ai/v2
